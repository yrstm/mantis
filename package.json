{
  "name": "@yrstm/mantis",
  "version": "0.3.2",
  "description": "Capture rendered web pages as structured JSON and clean Markdown for agents. Zero runtime dependencies, single file extraction core.",
  "main": "mantis.js",
  "types": "mantis.d.ts",
  "files": [
    "examples/",
    "mantis.d.ts",
    "mantis.js",
    "llms.txt",
    "README.md",
    "NOTICE",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "homepage": "https://yrstm.github.io/mantis/",
  "bugs": {
    "url": "https://github.com/yrstm/mantis/issues"
  },
  "scripts": {
    "benchmark": "node benchmark.js",
    "demo": "node demo/server.js",
    "pack:check": "npm pack --dry-run",
    "perf": "node perf.js",
    "test": "node test.js",
    "test:browser": "node demo/browser-test.js",
    "types:check": "tsc --noEmit --strict --lib dom,es2020 --module commonjs types-smoke.ts"
  },
  "keywords": [
    "readability",
    "article-extraction",
    "dom-extraction",
    "client-side",
    "markdown",
    "html-to-markdown",
    "llm",
    "ai-agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yrstm/mantis.git"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "typescript": "^5.9.3"
  }
}
